# =============================================================================
# Novita 中转 API key 配置
# =============================================================================
# 把本文件复制为 .env 后,把 sk-xxx 替换成你的真实 Novita key:
#   cp .env.example .env
#
# 项目统一走 Novita 的 anthropic 兼容协议 (LangChain ChatAnthropic).
# 模型清单由 app/agent/config/models.json 管理,不在此处配置.
# =============================================================================

# ---------- Novita 中转 (anthropic 兼容协议) ----------
ANTHROPIC_API_KEY=sk-xxx
ANTHROPIC_BASE_URL=https://api.novita.ai/anthropic
